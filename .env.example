# Traefik Host rules + manifest liveUrl (always http(s)://<id>.<DOMAIN>/ under UberApp, no GitHub Pages).
# Local Docker: DOMAIN=localhost matches docker-compose defaults and stub URLs in projects.v1.json.
DOMAIN=portfolio.example.com

# Optional: local when Traefik is on 8080 — use with npm run manifest / deploy
# TRAEFIK_HTTP_PORT=8080
# UBERAPP_URL_SCHEME=http
# UBERAPP_PUBLIC_PORT=8080

# Optional: comma-separated catalog ids to skip stub routers (if you run them in docker-compose.apps.yml)
# STUB_EXCLUDE=dwani-ai-discovery,my-custom-service

# dwani-ai/workshop (Gradio) — set for live dwani API calls (optional if you only need the UI shell)
# DWANI_API_KEY=
# DWANI_API_BASE_URL=

# sachinsshetty/agent-olympics-school (Gradio UX) — FastAPI backend the UI calls (default: public school-server)
# SCHOOL_BACKEND_URL=https://school-server.dwani.ai/
