# syntax=docker/dockerfile:1
# FastAPI school API (sachinsshetty/agent-olympics-school backend/main.py, :8000).

FROM python:3.11-slim-bookworm
WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends git \
  && rm -rf /var/lib/apt/lists/*

ARG SCHOOL_REPO_URL=https://github.com/sachinsshetty/agent-olympics-school.git
RUN git clone --depth 1 "${SCHOOL_REPO_URL}" /tmp/repo \
  && cp -a /tmp/repo/backend/. /app \
  && rm -rf /tmp/repo

RUN pip install --no-cache-dir --upgrade pip \
  && pip install --no-cache-dir -r requirements.txt

ENV PYTHONUNBUFFERED=1
EXPOSE 8000

RUN useradd -m -u 1000 appuser \
  && chown -R appuser:appuser /app
USER appuser

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
