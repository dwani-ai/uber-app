{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "uber-app-projects-v1",
  "title": "UberApp projects manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "projects"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional pointer for IDE validation"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "projects": {
      "type": "array",
      "items": { "$ref": "#/$defs/project" }
    }
  },
  "$defs": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "repo", "categories", "docsUrl"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "subdomain": {
          "type": "string",
          "description": "Traefik/DNS label; Host(<subdomain>.${DOMAIN})"
        },
        "title": { "type": "string", "minLength": 1 },
        "repo": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$"
        },
        "categories": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["web", "ai"] }
        },
        "description": { "type": ["string", "null"] },
        "liveUrl": { "type": ["string", "null"] },
        "docsUrl": { "type": "string", "format": "uri" }
      }
    }
  }
}
